{
  "name": "anonbot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready anonymous Telegram messaging bot",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "migrate": "node src/db/migrate.js",
    "syntax-check": "node -e \"require('glob').sync('src/**/*.js').forEach(f => require('child_process').execSync('node --check ' + f))\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "nanoid": "^3.3.8",
    "pg": "^8.13.1",
    "telegraf": "^4.16.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  }
}
