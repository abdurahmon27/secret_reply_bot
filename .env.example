# Telegram bot token obtained from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=

# PostgreSQL connection string (example: postgres://user:pass@localhost:5432/anonbot)
DATABASE_URL=

# Redis connection string (example: redis://localhost:6379)
REDIS_URL=

# Secret used to HMAC sender_hash — must stay private and stable
HMAC_SECRET=

# "production" in prod, "development" locally
NODE_ENV=development

# Optional: override log level (silly|debug|info|warn|error). Defaults to "info" in prod, "debug" otherwise.
# LOG_LEVEL=info
